# ═══════════════════════════════════════════════════════════════════
# KnowHow · LLM 配置
# 复制此文件为 .env.local 并填入你的配置
# 不配置任何 Key → 自动降级为本地模拟回答，开箱即用
# ═══════════════════════════════════════════════════════════════════

# ─── 方式一：选择预设提供商（推荐，只需填一个变量） ──────────────

# 提供商: anthropic | openai | deepseek | custom
LLM_PROVIDER=anthropic

# 对应提供商的 API Key
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── 方式二：完全自定义（使用 custom 时或想覆盖预设时设置） ──────

# LLM_PROVIDER=custom
# LLM_API_KEY=sk-xxxxxxxx
# LLM_BASE_URL=https://your-llm-api.com/v1/chat/completions
# LLM_MODEL=your-model-name
# LLM_MAX_TOKENS=2048
# LLM_EXTRA_HEADERS={"X-Custom-Header":"value"}


# ─── 快捷预设有 ──────────────────────────────────────────────────

# 【Anthropic Claude】(默认)
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-api03-xxxxxxxxxxxxx
# → 模型: claude-sonnet-4-6, 端点: api.anthropic.com

# 【OpenAI】
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# → 模型: gpt-4o, 端点: api.openai.com

# 【DeepSeek】(国内可用，性价比高)
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# → 模型: deepseek-chat, 端点: api.deepseek.com

# 【阿里百炼 / 通义千问】
# LLM_PROVIDER=custom
# LLM_API_KEY=sk-xxxxxxxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# LLM_MODEL=qwen-plus

# 【硅基流动 SiliconFlow / 火山引擎 / 任意 OpenAI 兼容接口】
# LLM_PROVIDER=custom
# LLM_API_KEY=sk-xxxxxxxx
# LLM_BASE_URL=https://api.siliconflow.cn/v1/chat/completions
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct


# ─── 高级选项 ────────────────────────────────────────────────────

# 追加到 System Prompt 末尾，可以自定义 AI 行为
# LLM_SYSTEM_PROMPT_SUFFIX=请用马克·吐温的风格回答问题。

# Vercel KV（Sprint 2 缓存 + 事件追踪）
# 部署到 Vercel 后自动注入。本地开发不设置则自动降级。
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Admin 仪表盘密码保护（可选——不设置则允许所有访问）
# ADMIN_PASSWORD=your-password-here
